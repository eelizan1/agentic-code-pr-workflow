# Copy this file to .env and fill in the values.

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# GitHub personal access token with repo scope
GITHUB_TOKEN=

# Target repository in "owner/name" format. Must contain a task.md at repo root.
REPO_NAME=eelizan1/agent-task-uncompress

# Optional: Anthropic model name (defaults to the value used in the notebook)
# ANTHROPIC_MODEL=claude-opus-4-6

# Optional: max generate/test retry iterations (defaults to 3)
# MAX_ITERATIONS=3

# Optional: max tokens per Anthropic completion (defaults to 8192).
# Increase if the model truncates long solutions.
# ANTHROPIC_MAX_TOKENS=8192
